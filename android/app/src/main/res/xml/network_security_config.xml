<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuración de producción: solo tráfico HTTPS, hacia cualquier dominio
    (Supabase, Google Vision). El build de debug sobreescribe este mismo
    archivo (ver app/src/debug/res/xml/network_security_config.xml) para
    permitir HTTP en loopback/emulador durante pruebas locales, sin debilitar
    la seguridad del APK que se publica.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
